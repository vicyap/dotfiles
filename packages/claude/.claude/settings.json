{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_STOP_HOOK_BLOCK_CAP": "100"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agent-system-info"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-worktree-create",
            "timeout": 300,
            "statusMessage": "Setting up worktree (env, deps, hooks)..."
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": false,
    "linear@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "posthog@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "usetemi-private@usetemi-private": true,
    "usetemi@usetemi": true,
    "stripe@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "resend@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "usetemi": {
      "source": {
        "source": "github",
        "repo": "usetemi/skills"
      }
    },
    "usetemi-private": {
      "source": {
        "source": "github",
        "repo": "usetemi/skills-private"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "ghostty",
  "autoCompactEnabled": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": false,
  "useAutoModeDuringPlan": true,
  "voiceEnabled": true
}
