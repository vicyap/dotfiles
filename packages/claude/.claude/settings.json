{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-worktree-create",
            "timeout": 300,
            "statusMessage": "Setting up worktree (env, deps, hooks)..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": false,
    "codex@openai-codex": true,
    "context7@claude-plugins-official": true,
    "posthog@claude-plugins-official": true,
    "usetemi@usetemi": true,
    "usetemi-private@usetemi-private": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "usetemi": {
      "source": {
        "source": "github",
        "repo": "usetemi/skills"
      }
    },
    "usetemi-private": {
      "source": {
        "source": "github",
        "repo": "usetemi/skills-private"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "ghostty",
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
