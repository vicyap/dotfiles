[user]
    name = Victor Yap
    email = vicyap@users.noreply.github.com

[init]
    defaultBranch = main

[core]
    editor = vim
    autocrlf = input
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true

[pull]
    ff = only

[push]
    default = current
    autoSetupRemote = true

[alias]
    initer = "!f() { git init && git commit --allow-empty --allow-empty-message --message ''; }; f"

[color]
    ui = auto

[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[filter "ghostty-theme"]
	clean = sed 's/^theme = .*/theme = TokyoNight Night/'
	smudge = cat
