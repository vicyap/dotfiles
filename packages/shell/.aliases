# Shared shell aliases

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ls (prefer eza when available)
if command -v eza &>/dev/null; then
  # Wrapper that translates common ls flags that are incompatible with eza:
  #   ls -t (sort by time)   -> eza --sort=modified  (eza's -t needs a value)
  #   ls -S (sort by size)   -> eza --sort=size       (eza's -S means blocksize)
  #   ls -h (human-readable) -> stripped              (eza always uses human-readable)
  unalias ls 2>/dev/null
  function ls {
    local args=()
    local sort_flag=""
    for arg in "$@"; do
      if [[ "$arg" == -* && "$arg" != --* ]]; then
        local cleaned="$arg"
        if [[ "$cleaned" == *t* ]]; then
          cleaned="${cleaned//t/}"
          sort_flag="--sort=modified"
        fi
        if [[ "$cleaned" == *S* ]]; then
          cleaned="${cleaned//S/}"
          sort_flag="--sort=size"
        fi
        cleaned="${cleaned//h/}"
        [[ "$cleaned" != "-" ]] && args+=("$cleaned")
      else
        args+=("$arg")
      fi
    done
    [[ -n "$sort_flag" ]] && args+=("$sort_flag")
    command eza "${args[@]}"
  }
  alias ll='eza -la --git'
  alias la='eza -a'
  alias l='eza -F'
  alias ltree='eza --tree --level=2'
else
  alias ll='ls -alF'
  alias la='ls -A'
  alias l='ls -CF'
fi

# Safety
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Git
alias g='git'
alias ga='git add'
alias gaa='git add --all'
alias gb='git branch'
alias gba='git branch -a'
alias gc='git commit'
alias gcmsg='git commit -m'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gcl='git clone'
alias gcp='git cherry-pick'
alias gd='git diff'
alias gds='git diff --staged'
alias gf='git fetch'
alias gl='git pull'
alias glg='git log --graph --decorate --stat --color'
alias glog='git log --oneline --graph --decorate'
alias gm='git merge'
alias gp='git push'
alias gpom='git pull origin main'
alias ggpush='git push origin $(git branch --show-current)'
alias ggpull='git pull origin $(git branch --show-current)'
alias grb='git rebase'
alias grh='git reset HEAD'
alias gst='git status'
alias gsta='git stash'
alias gstp='git stash pop'

# Claude
alias cc='claude'
function ccc {
  local prompt
  prompt=$(cat <<'PROMPT'
Create a git commit from the currently staged files only.

Workflow:
1. Gather all context in ONE bash call by running this single chained command:
       git diff --cached --name-only; echo ===STATUS===; git status -s; echo ===DIFF===; git diff --cached; echo ===LOG===; git log -5 --oneline

   - If the section before ===STATUS=== is empty, print "No staged changes." and exit without committing.
   - If the ===STATUS=== section shows unstaged or untracked files that look like they should be part of this commit (paired source/test files, related files in the same package, files referenced by the staged diff), print which files appear to belong and exit WITHOUT committing. Do NOT git add anything yourself.

2. Otherwise, write the commit message and commit + show the result in ONE bash call:
       git commit -F - <<'MSG' && git log -1 --stat
       <subject line>
       <blank line and body, if any>
       MSG

   Print the git log -1 --stat output verbatim.

Output rules:
- Output plain text only. Never use markdown code fences, backticks, or any markdown formatting.

Message style:
- Imperative mood: "add", "fix", "remove" (never "added", "fixes")
- Lowercase first word in the subject
- Subject <=72 characters, no trailing period
- Subject-only for trivial or obvious changes
- Add a body (blank line, then text wrapped at 72) only when the *why* is not obvious from the diff; explain motivation and context, not what the diff already shows
- Plain, factual language; avoid inflated words (critical, crucial, essential, significant, comprehensive, robust, elegant)
- No meta-commentary (test counts, CI status, tool versions)
- No AI co-authorship attribution or trailers
PROMPT
)
  # Run claude in the background so we can forward SIGINT to it on Ctrl+C.
  claude -p --model sonnet --effort low --disable-slash-commands "$prompt" &
  local pid=$!
  trap 'kill -INT $pid 2>/dev/null' INT
  wait $pid
  local code=$?
  trap - INT
  return $code
}

# Dev
alias nr='npm run'

# Misc
alias c='clear'
alias h='history'
alias grep='grep --color=auto'
alias df='df -h'
alias du='du -h'

# Linux-specific package name aliases
if [[ "$(uname)" != "Darwin" ]]; then
  alias fd='fdfind'
  alias bat='batcat'
fi
