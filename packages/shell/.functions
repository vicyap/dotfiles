# shellcheck shell=bash
# ~/.functions — multi-line shell helpers (sourced by zsh and bash)
# Style: omarchy-inspired ergonomic wrappers around tar/imagemagick/ffmpeg/ssh.

# ---------------------------------------------------------------------------
# Compression
# ---------------------------------------------------------------------------

# compress <path> — create <path>.tar.gz from a file or directory
function compress {
    if [[ $# -lt 1 ]]; then
        echo "usage: compress <path>" >&2
        return 1
    fi
    if [[ ! -e "$1" ]]; then
        echo "compress: '$1' does not exist" >&2
        return 1
    fi
    tar -czf "$1.tar.gz" "$1"
}

# decompress <archive> — expand tar.gz, tgz, tar.bz2, tar.xz, tar, zip, gz, bz2, xz
function decompress {
    if [[ $# -lt 1 ]]; then
        echo "usage: decompress <archive>" >&2
        return 1
    fi
    if [[ ! -f "$1" ]]; then
        echo "decompress: '$1' is not a file" >&2
        return 1
    fi
    case "$1" in
        *.tar.gz | *.tgz) tar -xzf "$1" ;;
        *.tar.bz2 | *.tbz2) tar -xjf "$1" ;;
        *.tar.xz | *.txz) tar -xJf "$1" ;;
        *.tar) tar -xf "$1" ;;
        *.zip) unzip "$1" ;;
        *.gz) gunzip "$1" ;;
        *.bz2) bunzip2 "$1" ;;
        *.xz) unxz "$1" ;;
        *)
            echo "decompress: don't know how to extract '$1'" >&2
            return 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Image conversion (ImageMagick)
# ---------------------------------------------------------------------------

# Pick `magick` (ImageMagick 7) or `convert` (ImageMagick 6).
function _magick_cmd {
    if command -v magick &>/dev/null; then
        echo magick
    elif command -v convert &>/dev/null; then
        echo convert
    else
        return 1
    fi
}

# img2jpg <input> — near-full-quality JPG (quality 92)
function img2jpg {
    local cmd
    cmd="$(_magick_cmd)" || {
        echo "img2jpg: ImageMagick not installed" >&2
        return 1
    }
    [[ $# -lt 1 ]] && {
        echo "usage: img2jpg <input>" >&2
        return 1
    }
    "$cmd" "$1" -quality 92 "${1%.*}.jpg"
}

# img2jpg-small <input> — JPG capped at 1920x1080 (preserves aspect)
function img2jpg-small {
    local cmd
    cmd="$(_magick_cmd)" || {
        echo "img2jpg-small: ImageMagick not installed" >&2
        return 1
    }
    [[ $# -lt 1 ]] && {
        echo "usage: img2jpg-small <input>" >&2
        return 1
    }
    "$cmd" "$1" -resize '1920x1080>' -quality 92 "${1%.*}-small.jpg"
}

# img2jpg-medium <input> — JPG capped at 3200x1800
function img2jpg-medium {
    local cmd
    cmd="$(_magick_cmd)" || {
        echo "img2jpg-medium: ImageMagick not installed" >&2
        return 1
    }
    [[ $# -lt 1 ]] && {
        echo "usage: img2jpg-medium <input>" >&2
        return 1
    }
    "$cmd" "$1" -resize '3200x1800>' -quality 92 "${1%.*}-medium.jpg"
}

# img2png <input> — compressed-but-lossless PNG
function img2png {
    local cmd
    cmd="$(_magick_cmd)" || {
        echo "img2png: ImageMagick not installed" >&2
        return 1
    }
    [[ $# -lt 1 ]] && {
        echo "usage: img2png <input>" >&2
        return 1
    }
    "$cmd" "$1" -define png:compression-level=9 "${1%.*}.png"
}

# ---------------------------------------------------------------------------
# Video transcoding (ffmpeg)
# ---------------------------------------------------------------------------

# transcode-video-1080p <input> — H.264 1080p MP4, AAC 192k
function transcode-video-1080p {
    command -v ffmpeg &>/dev/null || {
        echo "ffmpeg not installed" >&2
        return 1
    }
    [[ $# -lt 1 ]] && {
        echo "usage: transcode-video-1080p <input>" >&2
        return 1
    }
    ffmpeg -i "$1" \
        -vf "scale='min(1920,iw)':-2" \
        -c:v libx264 -crf 20 -preset slow \
        -c:a aac -b:a 192k \
        "${1%.*}-1080p.mp4"
}

# transcode-video-4K <input> — H.264 4K MP4, AAC 256k
function transcode-video-4K {
    command -v ffmpeg &>/dev/null || {
        echo "ffmpeg not installed" >&2
        return 1
    }
    [[ $# -lt 1 ]] && {
        echo "usage: transcode-video-4K <input>" >&2
        return 1
    }
    ffmpeg -i "$1" \
        -vf "scale='min(3840,iw)':-2" \
        -c:v libx264 -crf 18 -preset slow \
        -c:a aac -b:a 256k \
        "${1%.*}-4K.mp4"
}

# ---------------------------------------------------------------------------
# SSH port forwarding
# ---------------------------------------------------------------------------

# fip <host> <port> [<port>...] — forward remote ports to localhost via ssh -fN
function fip {
    if [[ $# -lt 2 ]]; then
        echo "usage: fip <host> <port> [<port>...]" >&2
        return 1
    fi
    local host=$1
    shift
    local args=()
    local port
    for port in "$@"; do
        args+=(-L "${port}:localhost:${port}")
    done
    if ssh -fN "${args[@]}" "$host"; then
        echo "forwarded $* from $host to localhost"
    else
        echo "fip: failed to forward $* from $host" >&2
        return 1
    fi
}

# dip <port> [<port>...] — disconnect forwards for given local ports
function dip {
    if [[ $# -lt 1 ]]; then
        echo "usage: dip <port> [<port>...]" >&2
        return 1
    fi
    local port pids found=0
    for port in "$@"; do
        pids="$(pgrep -f "ssh -fN.*-L ${port}:" 2>/dev/null || true)"
        if [[ -n "$pids" ]]; then
            echo "$pids" | xargs kill
            echo "disconnected port $port (pids: $(echo "$pids" | tr '\n' ' '))"
            found=1
        else
            echo "no forward found for port $port" >&2
        fi
    done
    [[ $found -eq 1 ]]
}

# lip — list active ssh -fN port forwards
function lip {
    if pgrep -af 'ssh -fN.*-L ' >/dev/null 2>&1; then
        pgrep -af 'ssh -fN.*-L '
    else
        echo "no active ssh port forwards"
    fi
}

# ---------------------------------------------------------------------------
# Scratch directories
# ---------------------------------------------------------------------------

# try [name] — cd into a date-stamped scratch dir under ${TMPDIR:-/tmp}/tries
function try {
    local tmp="${TMPDIR:-/tmp}"
    local base="${tmp%/}/tries"
    local stamp
    stamp="$(date +%F)"
    local dir
    if [[ $# -ge 1 ]]; then
        dir="${base}/${stamp}-${1}"
    else
        dir="${base}/${stamp}"
    fi
    mkdir -p "$dir" && cd "$dir" || return
}

# ---------------------------------------------------------------------------
# ls / git-commit / file-finder
# Functions (not aliases), so they live here where both zsh (via home-manager's
# baked rc) and bash (which sources this file) pick them up.
# ---------------------------------------------------------------------------

# ls — eza wrapper translating common ls flags that are incompatible with eza:
#   ls -t (sort by time)   -> eza --sort=modified  (eza's -t needs a value)
#   ls -S (sort by size)   -> eza --sort=size       (eza's -S means blocksize)
#   ls -h (human-readable) -> stripped              (eza always uses human-readable)
if command -v eza &>/dev/null; then
  unalias ls 2>/dev/null
  function ls {
    local args=()
    local sort_flag=""
    for arg in "$@"; do
      if [[ "$arg" == -* && "$arg" != --* ]]; then
        local cleaned="$arg"
        if [[ "$cleaned" == *t* ]]; then
          cleaned="${cleaned//t/}"
          sort_flag="--sort=modified"
        fi
        if [[ "$cleaned" == *S* ]]; then
          cleaned="${cleaned//S/}"
          sort_flag="--sort=size"
        fi
        cleaned="${cleaned//h/}"
        [[ "$cleaned" != "-" ]] && args+=("$cleaned")
      else
        args+=("$arg")
      fi
    done
    [[ -n "$sort_flag" ]] && args+=("$sort_flag")
    command eza "${args[@]}"
  }
fi

# ccc — AI-driven git commit (single Claude call, no tools)
function ccc {
  # Bail early if nothing is staged.
  local staged
  staged=$(git diff --cached --name-only)
  if [[ -z "$staged" ]]; then
    echo "No staged changes."
    return 0
  fi

  # Gather all git context locally — no model round-trips needed.
  local git_status git_diff git_log
  git_status=$(git status -s)
  git_diff=$(git diff --cached)
  git_log=$(git log -5 --oneline 2>/dev/null || true)

  local instructions
  instructions=$(cat <<'INSTRUCTIONS'
You will receive git context below. Decide between two outputs.

CASE A: If any UNSTAGED or UNTRACKED files in STATUS look like they should
be part of this commit (paired source/test files, related files in the same
package, files referenced by the staged diff), output exactly:

RELATED_UNSTAGED
<one filename per line>

CASE B: Otherwise, output exactly:

COMMIT
<subject line>
<optional blank line + body wrapped at 72 cols>

Output rules:
- Plain text only. No markdown, no code fences, no backticks.
- The first line MUST be exactly "RELATED_UNSTAGED" or "COMMIT".

Message style:
- Imperative mood: "add", "fix", "remove" (never "added", "fixes")
- Lowercase first word of subject
- Subject <=72 characters, no trailing period
- Subject-only for trivial or obvious changes
- Add a body (blank line, then text wrapped at 72) only when the *why* is
  not obvious from the diff; explain motivation, not what the diff shows
- Plain, factual language; avoid inflated words (critical, crucial,
  essential, significant, comprehensive, robust, elegant)
- No meta-commentary (test counts, CI status, tool versions)
- No AI co-authorship attribution or trailers
INSTRUCTIONS
)

  local prompt="${instructions}

==STATUS==
${git_status}

==STAGED DIFF==
${git_diff}

==RECENT COMMITS==
${git_log}"

  # Single LLM call with no tools and no agent loop.
  # Foreground so Ctrl+C from the terminal hits claude directly.
  local response
  response=$(claude -p \
    --model sonnet \
    --effort low \
    --tools "" \
    --disable-slash-commands \
    --no-session-persistence \
    "$prompt") || return $?

  local marker
  marker=$(head -n 1 <<<"$response")

  case "$marker" in
    RELATED_UNSTAGED)
      echo "Possibly related unstaged files:"
      tail -n +2 <<<"$response"
      echo
      echo "Stage them with 'git add' if they belong, then re-run ccc."
      return 1
      ;;
    COMMIT)
      tail -n +2 <<<"$response" | git commit -F - >/dev/null && git log -1 --stat
      ;;
    *)
      echo "Unexpected response from claude:" >&2
      printf '%s\n' "$response" >&2
      return 1
      ;;
  esac
}

# ff — fuzzy file finder; pick a file with fzf and open in $EDITOR
function ff {
  local fd_cmd
  if command -v fd &>/dev/null; then
    fd_cmd='fd --type f --hidden --follow --exclude .git'
  else
    fd_cmd='fdfind --type f --hidden --follow --exclude .git'
  fi
  local file
  file="$(eval "$fd_cmd" | fzf --preview 'bat --style=numbers --color=always --line-range=:200 {} 2>/dev/null || batcat --style=numbers --color=always --line-range=:200 {}' --preview-window=right:60%:wrap)"
  [[ -n "$file" ]] && "${EDITOR:-vim}" "$file"
}
