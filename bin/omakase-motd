#!/usr/bin/env bash
# omakase-motd — printed on shell login to keep the curated toolkit in muscle memory.
# Disable per-shell with OMAKASE_MOTD_OFF=1; remove the call from .zprofile/.bash_profile to disable globally.

[[ -t 1 && "${TERM:-}" != "dumb" && -z "${OMAKASE_MOTD_OFF:-}" ]] || exit 0

bold=$(tput bold 2> /dev/null || true)
dim=$(tput dim 2> /dev/null || true)
reset=$(tput sgr0 2> /dev/null || true)

cat << EOF

  ${bold}omakase${reset}  ${dim}— type${reset} ${bold}oma${reset} ${dim}for the full cheatsheet${reset}

  ${bold}Search    ${reset}  rg ${dim}(grep)${reset}    fd ${dim}(find)${reset}
  ${bold}View      ${reset}  bat ${dim}(cat)${reset}    eza ${dim}(ls)${reset}     chafa ${dim}(img)${reset}
  ${bold}Inspect   ${reset}  dust ${dim}(du)${reset}    dog ${dim}(dig)${reset}    btop   fastfetch
  ${bold}Data      ${reset}  jq           yq ${dim}(yaml)${reset}
  ${bold}Funcs     ${reset}  try  compress  decompress  img2{jpg,png}  transcode-video-*

EOF
