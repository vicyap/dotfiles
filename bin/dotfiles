#!/usr/bin/env bash
# Dotfiles CLI — a thin dispatcher over the shared install/converge/refresh
# helpers defined in install.sh. `install.sh` is the fresh-machine entrypoint;
# this command keeps an already-cloned machine in sync.
set -e

# Resolve the repo root from this script (follows symlinks, so it works for
# worktree checkouts and a ~/.local/bin symlink). DOTFILES_DIR overrides it.
if [[ -z "${DOTFILES_DIR:-}" ]]; then
    src="${BASH_SOURCE[0]}"
    while [[ -L "$src" ]]; do
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    DOTFILES_DIR="$(cd -P "$(dirname "$src")/.." && pwd)"
fi
export DOTFILES_DIR
export PATH="$HOME/.local/bin:$HOME/go/bin:$PATH"

usage() {
    cat <<EOF
Usage: dotfiles <command>

Commands:
  pull      Pull latest, then converge this machine: symlinks, home-manager,
            generated config, pinned tools. Fast and repeatable. (alias: sync)
  update    pull + refresh upstream: Nix flake inputs, Homebrew/apt packages,
            mise upgrades, Claude/Codex plugins, agent-skill registries.
  status    Show git status of the dotfiles repo.
  cd        Print the dotfiles directory (the shell wraps this to actually cd).
  edit      Open the dotfiles directory in \$EDITOR.
  local     Edit ~/.agents/rules/local.md (machine-specific rules).
  help      Show this help message.

Fresh machine: run ./install.sh (or pipe it from curl); see README.
EOF
}

load_libs() {
    # shellcheck source=/dev/null
    source "$DOTFILES_DIR/lib/platform.sh"
    # shellcheck source=/dev/null
    source "$DOTFILES_DIR/lib/symlink.sh"
    # install.sh defines converge/refresh_upstream and the helpers they call;
    # its main() is guarded so sourcing only defines functions.
    # shellcheck source=/dev/null
    source "$DOTFILES_DIR/install.sh"
}

cmd_pull() {
    echo "Pulling + converging dotfiles..."
    git -C "$DOTFILES_DIR" pull --rebase
    echo
    load_libs
    converge
}

cmd_update() {
    echo "Updating dotfiles (pull + converge + upstream refresh)..."
    git -C "$DOTFILES_DIR" pull --rebase
    echo
    load_libs
    converge
    refresh_upstream
}

cmd_status() {
    git -C "$DOTFILES_DIR" status
}

cmd_cd() {
    echo "$DOTFILES_DIR"
}

cmd_edit() {
    ${EDITOR:-vim} "$DOTFILES_DIR"
}

cmd_local() {
    local rules_dir="$HOME/.agents/rules"
    local claude_rules_dir="$HOME/.claude/rules"
    local local_file="$rules_dir/local.md"
    local example_file="$rules_dir/local.example"
    local old_local_file="$claude_rules_dir/local.md"

    if [[ ! -f "$local_file" ]]; then
        if [[ -f "$old_local_file" && ! -L "$old_local_file" ]]; then
            mkdir -p "$rules_dir"
            cp "$old_local_file" "$local_file"
            echo "Created $local_file from existing Claude local rules"
        elif [[ -f "$example_file" ]]; then
            cp "$example_file" "$local_file"
            echo "Created $local_file from template"
        else
            mkdir -p "$rules_dir"
            echo "# Local Rules" >"$local_file"
            echo "Created $local_file"
        fi
    fi

    mkdir -p "$claude_rules_dir"
    if [[ -L "$old_local_file" ]]; then
        if [[ "$(readlink "$old_local_file")" != "$local_file" ]]; then
            rm -f "$old_local_file"
            ln -s "$local_file" "$old_local_file"
        fi
    elif [[ ! -e "$old_local_file" ]]; then
        ln -s "$local_file" "$old_local_file"
    elif cmp -s "$old_local_file" "$local_file"; then
        rm -f "$old_local_file"
        ln -s "$local_file" "$old_local_file"
    else
        echo "Skipped Claude local rule link: $old_local_file already exists with different content"
    fi

    ${EDITOR:-vim} "$local_file"
}

main() {
    local cmd="${1:-help}"

    case "$cmd" in
        pull | sync) cmd_pull ;;
        update) cmd_update ;;
        status) cmd_status ;;
        cd) cmd_cd ;;
        edit) cmd_edit ;;
        local) cmd_local ;;
        help | -h | --help) usage ;;
        *)
            echo "Unknown command: $cmd"
            usage
            exit 1
            ;;
    esac
}

main "$@"
