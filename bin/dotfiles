#!/usr/bin/env bash
# Dotfiles CLI

DOTFILES_DIR="$HOME/.dotfiles"
export PATH="$HOME/.local/bin:$HOME/go/bin:$PATH"

usage() {
  cat <<EOF
Usage: dotfiles <command>

Commands:
  bootstrap       Install bootstrap packages, then run install.sh
  sync            Pull latest, re-symlink, and install/update tools
  status          Show git status of dotfiles repo
  edit            Open dotfiles directory in \$EDITOR
  local           Edit ~/.agents/rules/local.md (machine-specific rules)
  cd              Print dotfiles directory (use: cd \$(dotfiles cd))
  help            Show this help message
EOF
}

cmd_bootstrap() {
  echo "Bootstrapping dotfiles..."
  "$DOTFILES_DIR/install.sh"
}

cmd_sync() {
  echo "Syncing dotfiles..."
  git -C "$DOTFILES_DIR" pull --rebase
  echo
  echo "Re-symlinking packages..."
  source "$DOTFILES_DIR/lib/symlink.sh"
  symlink_all_packages "$DOTFILES_DIR/packages"
  echo
  # Source helpers for migrate_skill_configs, generate_codex_config, setup_codex_plugins, setup_claude_plugins
  source "$DOTFILES_DIR/lib/platform.sh"
  source "$DOTFILES_DIR/install.sh"
  echo "Syncing Claude Code rules..."
  sync_claude_rules
  echo
  case "$(uname -s)" in
  Darwin)
    if command -v brew &>/dev/null; then
      echo "Installing Brewfile entries..."
      brew bundle --file="$DOTFILES_DIR/platform/macos/Brewfile"
      echo
    fi
    ;;
  esac
  echo "Migrating skill config directories..."
  migrate_skill_configs
  echo
  echo "Generating codex config..."
  generate_codex_config
  echo
  echo "Installing Codex plugins..."
  setup_codex_plugins
  echo
  echo "Installing Claude Code plugins..."
  setup_claude_plugins
  echo
  if command -v mise &>/dev/null; then
    echo "Installing mise tools..."
    mise install --yes
    echo
    echo "Updating CLI tools..."
    mise run update:tools
    echo
  else
    echo "Skipped tool install: mise not found"
    echo
  fi
  echo "Installing agent skills..."
  install_agent_skills
  echo
  echo "Installing Codex skills..."
  install_codex_skills
  echo
  echo "Syncing dotfiles agent skills..."
  sync_dotfiles_agent_skills
  echo
  echo "Pruning excluded agent skills..."
  prune_excluded_agent_skills
  echo
  echo "Syncing Claude Code skills..."
  sync_claude_skills
}

cmd_status() {
  git -C "$DOTFILES_DIR" status
}

cmd_edit() {
  ${EDITOR:-vim} "$DOTFILES_DIR"
}

cmd_cd() {
  echo "$DOTFILES_DIR"
}

cmd_local() {
  local rules_dir="$HOME/.agents/rules"
  local claude_rules_dir="$HOME/.claude/rules"
  local local_file="$rules_dir/local.md"
  local example_file="$rules_dir/local.example"
  local old_local_file="$claude_rules_dir/local.md"

  if [[ ! -f "$local_file" ]]; then
    if [[ -f "$old_local_file" && ! -L "$old_local_file" ]]; then
      mkdir -p "$rules_dir"
      cp "$old_local_file" "$local_file"
      echo "Created $local_file from existing Claude local rules"
    elif [[ -f "$example_file" ]]; then
      cp "$example_file" "$local_file"
      echo "Created $local_file from template"
    else
      mkdir -p "$rules_dir"
      echo "# Local Rules" >"$local_file"
      echo "Created $local_file"
    fi
  fi

  mkdir -p "$claude_rules_dir"
  if [[ -L "$old_local_file" ]]; then
    if [[ "$(readlink "$old_local_file")" != "$local_file" ]]; then
      rm -f "$old_local_file"
      ln -s "$local_file" "$old_local_file"
    fi
  elif [[ ! -e "$old_local_file" ]]; then
    ln -s "$local_file" "$old_local_file"
  elif cmp -s "$old_local_file" "$local_file"; then
    rm -f "$old_local_file"
    ln -s "$local_file" "$old_local_file"
  else
    echo "Skipped Claude local rule link: $old_local_file already exists with different content"
  fi

  ${EDITOR:-vim} "$local_file"
}

main() {
  local cmd="${1:-help}"

  case "$cmd" in
  bootstrap) cmd_bootstrap ;;
  sync) cmd_sync ;;
  status) cmd_status ;;
  edit) cmd_edit ;;
  local) cmd_local ;;
  cd) cmd_cd ;;
  help) usage ;;
  *)
    echo "Unknown command: $cmd"
    usage
    exit 1
    ;;
  esac
}

main "$@"
